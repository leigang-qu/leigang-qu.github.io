---
layout: default
---
<div class="post">
  <header class="post-header">
    {% if page.profile -%}
      <div class="profile float-{%- if page.profile.align == 'left' -%}left{%- else -%}right{%- endif -%}">
        {%- if page.profile.image %}
          {%- assign profile_image_path = page.profile.image | prepend: 'assets/img/' -%}

          {% if page.profile.image_circular %}
            {%- assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' -%}
          {% else %}
            {%- assign profile_image_class = 'img-fluid z-depth-1 rounded' -%}
          {% endif %}

          {%
            include figure.liquid
            path=profile_image_path
            class=profile_image_class
            alt=page.profile.image
          -%}
        {% endif -%}
      </div>
    {%- endif %}

    <h1 class="post-title">
      {% if site.title == 'blank' -%}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {%- else -%}
        {{ site.title }}
      {%- endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
    {%- if page.profile.address %}
      <div class="address">
        {{ page.profile.address }}
      </div>
    {%- endif %}

    {%- if page.social %}
      <!-- Social -->
      <div class="social">
        <div class="contact-icons">
          {% include social.liquid %}
        </div>

        <div class="contact-note">
          {{ site.contact_note }}
        </div>
      </div>
    {%- endif %}
  </header>

  <article>
    <div class="clearfix">
      <br>
      {{ content }}
    </div>
  </article>

  <!-- Opening highlight -->
  <div class="opening-box">
    <strong>Openings:</strong> We welcome motivated Ph.D., M.S., and undergraduate students to join our group and work with Prof. Tat-Seng Chua and
    myself. Opportunities are open via CSC scholarships, research assistantships, visiting positions, and remote internships. If you are interested,
    please reach out at <a href="mailto:leigangqu@gmail.com">leigangqu@gmail.com</a> with your CV.
  </div>

  <!-- News -->
  {% if page.news and site.announcements.enabled -%}
    <h2>
      <a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a>
    </h2>
    {% include news.liquid limit=true %}
  {%- endif %}

  <!-- Latest posts -->
  {% if page.latest_posts %}
    <h2>
      <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
    </h2>
    {% include latest_posts.liquid %}
  {% endif %}

  <!-- Selected papers -->
  {% if page.selected_papers %}
    <br>
    <br>
    <h2>
      {% comment %} Selected Publications <a href="{{ '/publications/' | relative_url }}" style="color: inherit">[Full List]</a> {% endcomment %}
      Selected Publications/Preprints <a href="{{ '/publications/' | relative_url }}">[Full List]</a>
    </h2>
    {% include selected_papers.liquid %}
  {% endif %}

  <!-- Academic Services -->
  <h2 id="service">Academic Services</h2>
  <p>
    Invited Reviewer for TIP, TMM, TKDE, TOIS, TCSVT, ToMM, IPM, Information Sciences, Multimedia Systems, Neurocomputing<br>
    Invited Reviewer of ICML in 2024<br>
    Program Committee Member/Reviewer of NeurIPS, ACL, SIGIR, ACMMM, KDD, AAAI in 2024<br>
    Program Committee Member/Reviewer of SIGIR, ACMMM, AAAI, KDD, SIGIR-AP in 2023
  </p>

  <!-- Honors -->
  <h2 id="honors">Honors</h2>
  <p>
    &bull; Research Achievement Award, NUS SoC, 2023<br>
    &bull; Student Travel Grant, SIGIR, 2023<br>
    &bull; Best Paper Award, ACMMM, 2022<br>
    &bull; President's Graduate Fellowship, NUS, 2022<br>
    &bull; Best Student Paper Award, SIGIR, 2021
  </p>
</div>
